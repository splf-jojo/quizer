{
  "name": "quizzer-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:setup": "node src/db/setup.js",
    "db:init": "psql \"$DATABASE_URL\" -f src/db/init.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f src/db/seed.sql",
    "db:migrate": "node src/db/migrate.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  }
}
